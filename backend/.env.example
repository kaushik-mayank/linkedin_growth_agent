# Copy this file to ".env" in this same folder and fill in your real keys there.
# Never commit ".env" — it's already in .gitignore.

# Which provider /test-llm and the agent use by default: "groq" or "gemini"
LLM_PROVIDER=groq

# Groq — free tier. Get a key at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Gemini — used as fallback, and later for embeddings. Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Comma-separated list of frontend origins allowed to call this backend
ALLOWED_ORIGINS=http://localhost:3000

# We do not use the paid LangSmith/LangGraph Platform — keep this false
LANGCHAIN_TRACING_V2=false
